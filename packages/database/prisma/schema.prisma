generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum Platform {
  LINKEDIN
  FACEBOOK
  TIKTOK
  INSTAGRAM
}

enum NdaStatus {
  GENERATED
  SENT
  SIGNED
}

enum LeadSource {
  MANUAL
  AGENT
  BARK
  LINKEDIN_SALES_NAV
  APOLLO
  LINKEDIN_COMPANY_PAGE
  REFERRAL
  WEBSITE
  COLD_OUTREACH
  EVENT
  SMB_APP_CONTEST_2026
  SMB_NY_2026
  APP_FACTORY
  OTHER
}

enum AppFlowType {
  BASIC
  WIREFRAME
}

enum LeadStatus {
  NEW
  SOW_READY
  SOW_SIGNED
  APP_FLOW_READY
  DESIGN_READY
  DESIGN_APPROVED
  BUILD_IN_PROGRESS
  BUILD_READY_FOR_REVIEW
  BUILD_SUBMITTED
  GO_LIVE
  LOST
  NO_RESPONSE
  ON_HOLD
  CANCELLED
}

model AdminUser {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  username  String   @unique
  password  String
  active         Boolean  @default(true)
  profilePicture String?  @map("profile_picture")
  emailSignature String?  @db.Text @map("email_signature")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  assignedLeads  Lead[]       @relation("AssignedLeads")
  assignedTasks  NextStep[]   @relation("AssignedTasks")
  watchedLeads   LeadWatcher[]
  notificationPreference NotificationPreference?

  @@map("admin_users")
}

model Lead {
  id                 String       @id @default(uuid())
  projectName        String       @map("project_name")
  customerName       String       @map("customer_name")
  customerEmail      String       @map("customer_email")
  projectDescription String       @map("project_description") @db.Text
  source             LeadSource   @default(MANUAL)
  status             LeadStatus   @default(NEW)
  emailSent          Boolean      @default(false) @map("email_sent")
  doNotContact       Boolean      @default(false) @map("do_not_contact")
  createdBy          String?      @map("created_by")
  updatedBy          String?      @map("updated_by")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  phone          String?
  city           String?
  zip            String?
  dateCreated    DateTime?    @map("date_created")

  stage          LeadStage    @default(COLD)
  linkedinUrl    String?      @map("linkedin_url")
  apolloUrl      String?      @map("apollo_url")
  facebookUrl    String?      @map("facebook_url")
  twitterUrl     String?      @map("twitter_url")

  // Core contact fields
  jobTitle       String?      @map("job_title")
  companyName    String?      @map("company_name")
  location       String?

  // Company intelligence fields
  industry       String?
  companySize    String?      @map("company_size")
  companyWebsite String?      @map("company_website")
  aboutCompany   String?      @map("about_company") @db.Text
  naicsSectorCode    String?  @map("naics_sector_code")
  naicsSubsectorCode String?  @map("naics_subsector_code")

  // Lead management fields
  extractedDate      DateTime?  @map("extracted_date")
  lastContactedDate  DateTime?  @map("last_contacted_date")
  leadScore          Int?       @map("lead_score")

  // Outreach tracking fields
  connectionRequestSent  Boolean  @default(false)  @map("connection_request_sent")
  connectionAccepted     Boolean  @default(false)  @map("connection_accepted")
  initialMessageSent     Boolean  @default(false)  @map("initial_message_sent")
  meetingBooked          Boolean  @default(false)  @map("meeting_booked")
  meetingDate            DateTime? @map("meeting_date")
  responseReceived       Boolean  @default(false)  @map("response_received")

  assignedToId   String?      @map("assigned_to_id")
  assignedTo     AdminUser?   @relation("AssignedLeads", fields: [assignedToId], references: [id], onDelete: SetNull)

  zohoLeadId     String?      @map("zoho_lead_id")

  notes         Note[]
  statusHistory StatusHistory[]
  nda           Nda?
  sentEmails      SentEmail[]
  emailDrafts     EmailDraft[]
  messages        Message[]
  receivedEmails  ReceivedEmail[]
  files           LeadFile[]
  documents       LeadDocument[]
  contacts        LeadContact[]
  requirements    Requirement[]
  questionnaire   LeadQuestionnaire?
  scopeOfWorks    ScopeOfWork[]
  appFlows        AppFlow[]
  watchers        LeadWatcher[]
  customerVisits  CustomerVisit[]
  nextSteps            NextStep[]
  auditLogs            AuditLog[]
  sequenceEnrollments  SequenceEnrollment[]
  listMemberships      ListMembership[]
  meetingBookings      MeetingBooking[]

  @@map("leads")
}

model LeadWatcher {
  id        String    @id @default(uuid())
  leadId    String    @map("lead_id")
  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  adminId   String    @map("admin_id")
  admin     AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now()) @map("created_at")

  @@unique([leadId, adminId])
  @@map("lead_watchers")
}

model Note {
  id        String   @id @default(uuid())
  content   String   @db.Text
  leadId    String   @map("lead_id")
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notes")
}

model StatusHistory {
  id         String      @id @default(uuid())
  fromStatus LeadStatus? @map("from_status")
  toStatus   LeadStatus  @map("to_status")
  changedBy  String?     @map("changed_by")
  leadId     String      @map("lead_id")
  lead       Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now()) @map("created_at")

  @@map("status_history")
}

model Nda {
  id                 String    @id @default(uuid())
  leadId             String    @unique @map("lead_id")
  lead               Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  content            String    @db.Text
  status             NdaStatus @default(GENERATED)
  signerName         String?   @map("signer_name")
  signerIp           String?   @map("signer_ip")
  signedAt           DateTime? @map("signed_at")
  fileName           String?   @map("file_name")
  s3Key              String?   @map("s3_key") @db.Text
  fileSize           Int?      @map("file_size")
  mimeType           String?   @map("mime_type")
  uploadedExternally Boolean   @default(false) @map("uploaded_externally")
  uploadedBy         String?   @map("uploaded_by")
  createdAt          DateTime  @default(now()) @map("created_at")

  @@map("ndas")
}

model LeadFile {
  id         String   @id @default(uuid())
  leadId     String   @map("lead_id")
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  fileName   String   @map("file_name")
  filePath   String   @map("file_path")
  fileSize   Int      @map("file_size")
  fileType   String   @map("file_type")
  uploadedBy String?  @map("uploaded_by")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("lead_files")
}

model QuestionnaireTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  questions   Json     @default("[]")
  createdBy   String?  @map("created_by")
  updatedBy   String?  @map("updated_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("questionnaire_templates")
}

model LeadQuestionnaire {
  id           String    @id @default(uuid())
  leadId       String    @unique @map("lead_id")
  lead         Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  templateId   String?   @map("template_id")
  title        String
  description  String?   @db.Text
  questions    Json      @default("[]")
  answers      Json      @default("{}")
  status       String    @default("DRAFT")
  sentAt       DateTime? @map("sent_at")
  submittedAt  DateTime? @map("submitted_at")
  createdBy    String?   @map("created_by")
  updatedBy    String?   @map("updated_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("lead_questionnaires")
}

enum RequirementType {
  EPIC
  FEATURE
  USER_STORY
}

enum RequirementPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Requirement {
  id            String              @id @default(uuid())
  leadId        String              @map("lead_id")
  lead          Lead                @relation(fields: [leadId], references: [id], onDelete: Cascade)
  parentId      String?             @map("parent_id")
  parent        Requirement?        @relation("ChildRequirements", fields: [parentId], references: [id], onDelete: Cascade)
  children      Requirement[]       @relation("ChildRequirements")
  type          RequirementType
  title         String
  description   String?             @db.Text
  priority      RequirementPriority @default(MEDIUM)
  sortOrder     Int                 @default(0) @map("sort_order")
  createdBy     String?             @map("created_by")
  createdByType String?             @map("created_by_type")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  @@index([leadId])
  @@index([parentId])
  @@map("requirements")
}

model LeadContact {
  id        String   @id @default(uuid())
  leadId    String   @map("lead_id")
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  name      String
  email     String
  phone     String?
  role      String?
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([leadId])
  @@index([email])
  @@map("lead_contacts")
}

model LeadDocument {
  id             String   @id @default(uuid())
  leadId         String   @map("lead_id")
  lead           Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  fileName       String   @map("file_name")
  s3Key          String   @map("s3_key") @db.Text
  fileSize       Int      @map("file_size")
  mimeType       String   @map("mime_type")
  uploadedBy     String   @map("uploaded_by")
  uploadedByType String   @map("uploaded_by_type")
  uploadedById   String?  @map("uploaded_by_id")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([leadId])
  @@map("lead_documents")
}

enum LeadStage {
  COLD
  WARM
  HOT
  ACTIVE
  CLOSED
  NEW
  CONTACTED
  RESPONDED
  MEETING_BOOKED
  QUALIFIED
  DISQUALIFIED
  NURTURE
}

enum SentEmailStatus {
  SENT
  OPENED
  FAILED
}

enum EmailTemplatePurpose {
  WELCOME
  FOLLOW_UP
  REMINDER
  NOTIFICATION
  PROMOTIONAL
  NURTURE
  COLD_OUTREACH
  OTHER
}

model EmailTemplate {
  id        String               @id @default(uuid())
  title     String
  subject   String
  body      String               @db.Text
  tags      Json                 @default("[]")
  notes     String?              @db.Text @map("admin_notes")
  purpose   EmailTemplatePurpose @default(OTHER)
  sendAfterDays Int?             @map("send_after_days")
  industry  String?
  naicsSectorCode    String?    @map("naics_sector_code")
  naicsSubsectorCode String?    @map("naics_subsector_code")
  systemKey String?              @unique @map("system_key")
  createdBy String?              @map("created_by")
  updatedBy String?              @map("updated_by")
  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @updatedAt @map("updated_at")

  sentEmails    SentEmail[]
  sequenceSteps SequenceStep[]

  @@map("email_templates")
}

model Message {
  id         String   @id @default(uuid())
  leadId     String   @map("lead_id")
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  content    String   @db.Text
  senderName String   @map("sender_name")
  senderType String   @default("customer") @map("sender_type")
  readAt     DateTime? @map("read_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("messages")
}

model EmailDraft {
  id          String    @id @default(uuid())
  leadId      String    @map("lead_id")
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  subject     String    @default("")
  body        String    @db.Text @default("")
  cc          String?   @db.Text
  bcc         String?   @db.Text
  status      String    @default("DRAFT")
  scheduledAt DateTime? @map("scheduled_at")
  lockedUntil DateTime? @map("locked_until")
  retryCount  Int       @default(0) @map("retry_count")
  failureReason String? @map("failure_reason")
  sentAt      DateTime? @map("sent_at")
  sentEmailId String?   @map("sent_email_id")
  createdBy   String?   @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([status, scheduledAt, lockedUntil])
  @@map("email_drafts")
}

model SentEmail {
  id             String          @id @default(uuid())
  leadId         String          @map("lead_id")
  templateId     String?         @map("template_id")
  subject        String
  body           String          @db.Text
  status         SentEmailStatus @default(SENT)
  openedAt       DateTime?       @map("opened_at")
  clickedAt      DateTime?       @map("clicked_at")
  sentBy         String?         @map("sent_by")
  cc             String?         @db.Text
  bcc            String?         @db.Text
  replyToEmailId String?         @map("reply_to_email_id")
  replyToType    String?         @map("reply_to_type")
  enrollmentId   String?         @map("enrollment_id")
  enrollmentStep Int?            @map("enrollment_step")
  createdAt      DateTime        @default(now()) @map("created_at")

  lead        Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  template    EmailTemplate?    @relation(fields: [templateId], references: [id], onDelete: SetNull)
  attachments EmailAttachment[]

  @@unique([enrollmentId, enrollmentStep], map: "sent_email_enrollment_step_uq")
  @@map("sent_emails")
}

model EmailAttachment {
  id          String    @id @default(uuid())
  sentEmailId String    @map("sent_email_id")
  sentEmail   SentEmail @relation(fields: [sentEmailId], references: [id], onDelete: Cascade)
  fileName    String    @map("file_name")
  filePath    String    @map("file_path")
  fileSize    Int       @map("file_size")
  fileType    String    @map("file_type")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("email_attachments")
}

model ReceivedEmail {
  id          String   @id @default(uuid())
  leadId      String   @map("lead_id")
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  messageId   String?  @unique @map("message_id")
  fromEmail   String   @map("from_email")
  fromName    String?  @map("from_name")
  subject     String
  bodyText    String?  @db.Text @map("body_text")
  bodyHtml    String?  @db.Text @map("body_html")
  receivedAt  DateTime @default(now()) @map("received_at")

  @@map("received_emails")
}

model Content {
  id        String        @id @default(uuid())
  title     String
  body      String        @db.Text
  mediaUrl  String?       @map("media_url")
  mediaFile String?       @map("media_file")
  tags      Json          @default("[]")
  platforms Platform[]
  status    ContentStatus @default(DRAFT)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  @@map("content")
}

model SowTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  content     String   @db.Text
  fileName    String?  @map("file_name")
  filePath    String?  @map("file_path")
  fileSize    Int?     @map("file_size")
  fileType    String?  @map("file_type")
  industry    String?
  projectType String?  @map("project_type")
  durationRange String? @map("duration_range")
  costRange   String?  @map("cost_range")
  isDefault   Boolean  @default(false) @map("is_default")
  createdBy   String?  @map("created_by")
  updatedBy   String?  @map("updated_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("sow_templates")
}

model ScopeOfWork {
  id          String    @id @default(uuid())
  leadId      String    @map("lead_id")
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  version     Int       @default(1)
  fileName    String?   @map("file_name")
  filePath    String?   @map("file_path")
  fileSize    Int?      @map("file_size")
  fileType    String?   @map("file_type")
  content     String?   @db.Text
  isDraft     Boolean   @default(false) @map("is_draft")
  comments    String?   @db.Text
  uploadedBy  String?   @map("uploaded_by")
  sharedAt    DateTime? @map("shared_at")
  sharedBy    String?   @map("shared_by")
  signedAt    DateTime? @map("signed_at")
  signerName  String?   @map("signer_name")
  signerIp    String?   @map("signer_ip")
  createdAt   DateTime  @default(now()) @map("created_at")

  sowComments SowComment[]

  @@map("scope_of_works")
}

model SowComment {
  id           String      @id @default(uuid())
  sowId        String      @map("sow_id")
  scopeOfWork  ScopeOfWork @relation(fields: [sowId], references: [id], onDelete: Cascade)
  content      String      @db.Text
  authorName   String      @map("author_name")
  authorType   String      @default("customer") @map("author_type")
  createdAt    DateTime    @default(now()) @map("created_at")

  @@map("sow_comments")
}

model AppFlow {
  id          String      @id @default(uuid())
  leadId      String      @map("lead_id")
  lead        Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  name        String
  description String?     @db.Text
  flowType    AppFlowType @default(BASIC) @map("flow_type")
  nodes       Json        @default("[]")
  edges       Json        @default("[]")
  sharedAt    DateTime?   @map("shared_at")
  sharedBy    String?     @map("shared_by")
  createdBy   String?     @map("created_by")
  updatedBy   String?     @map("updated_by")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  comments    AppFlowComment[]

  @@map("app_flows")
}

model AppFlowComment {
  id         String   @id @default(uuid())
  appFlowId  String   @map("app_flow_id")
  appFlow    AppFlow  @relation(fields: [appFlowId], references: [id], onDelete: Cascade)
  content    String   @db.Text
  authorName String   @map("author_name")
  authorType String   @default("customer") @map("author_type")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("app_flow_comments")
}

enum AuthProvider {
  GOOGLE
  LINKEDIN
}

model AuditLog {
  id        String   @id @default(uuid())
  leadId    String   @map("lead_id")
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  action    String
  detail    String?  @db.Text
  actor     String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

model NextStep {
  id            String     @id @default(uuid())
  leadId        String     @map("lead_id")
  lead          Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  content       String     @db.Text
  dueDate       DateTime?  @map("due_date")
  completed     Boolean    @default(false)
  completedAt   DateTime?  @map("completed_at")
  createdBy     String?    @map("created_by")
  assignedById  String?    @map("assigned_by_id")
  assignedToId  String?    @map("assigned_to_id")
  assignedTo    AdminUser? @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdAt     DateTime   @default(now()) @map("created_at")

  @@map("next_steps")
}

model PortfolioService {
  id              String   @id @default(uuid())
  name            String
  description     String   @db.Text
  emailScript     String?  @map("email_script") @db.Text
  phoneScript     String?  @map("phone_script") @db.Text
  meetingScript   String?  @map("meeting_script") @db.Text
  documents       Json     @default("[]")
  urls            Json     @default("[]")
  sortOrder       Int      @default(0) @map("sort_order")
  createdBy       String?  @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  projects        PortfolioProject[]

  @@map("portfolio_services")
}

model PortfolioProject {
  id              String   @id @default(uuid())
  title           String
  description     String   @db.Text
  serviceId       String?  @map("service_id")
  service         PortfolioService? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  category        String?
  domain          String?
  industry        String?
  industrySector  String?  @map("industry_sector")
  industrySubsector String? @map("industry_subsector")
  technologies    Json     @default("[]")
  customerName    String?  @map("customer_name")
  customerDetail  String?  @map("customer_detail") @db.Text
  demoVideoUrl    String?  @map("demo_video_url")
  portfolioUrl    String?  @map("portfolio_url")
  customerReviewUrl String? @map("customer_review_url")
  additionalLinks Json     @default("[]") @map("additional_links")
  documents       Json     @default("[]")
  emailScript     String?  @map("email_script") @db.Text
  phoneScript     String?  @map("phone_script") @db.Text
  meetingScript   String?  @map("meeting_script") @db.Text
  completedAt     DateTime? @map("completed_at")
  createdBy       String?  @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("portfolio_projects")
}

model NaicsSector {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  subsectors  NaicsSubsector[]

  @@map("naics_sectors")
}

model NaicsSubsector {
  id          String      @id @default(uuid())
  code        String      @unique
  name        String
  sectorId    String      @map("sector_id")
  sector      NaicsSector @relation(fields: [sectorId], references: [id], onDelete: Cascade)

  @@map("naics_subsectors")
}

model KnowledgeArticle {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  content     String   @db.Text
  category    String
  tags        Json     @default("[]")
  sortOrder   Int      @default(0) @map("sort_order")
  published   Boolean  @default(true)
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("knowledge_articles")
}

model CustomerVisit {
  id        String   @id @default(uuid())
  leadId    String   @map("lead_id")
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  visitorEmail String? @map("visitor_email")
  visitorName  String? @map("visitor_name")
  page      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("customer_visits")
}

model NotificationPreference {
  id                    String   @id @default(uuid())
  adminId               String   @unique @map("admin_id")
  admin                 AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
  notificationEmail     String?  @map("notification_email")

  // Notification toggles (all default to true)
  newLeadCreated        Boolean  @default(true) @map("new_lead_created")
  emailSentToCustomer   Boolean  @default(true) @map("email_sent_to_customer")
  customerResponse      Boolean  @default(true) @map("customer_response")
  customerPortalVisit   Boolean  @default(true) @map("customer_portal_visit")
  customerComment       Boolean  @default(true) @map("customer_comment")
  leadStatusChange      Boolean  @default(true) @map("lead_status_change")
  leadAssigned          Boolean  @default(true) @map("lead_assigned")
  sowSigned             Boolean  @default(true) @map("sow_signed")
  ndaSigned             Boolean  @default(true) @map("nda_signed")
  taskCompleted         Boolean  @default(true) @map("task_completed")
  // Per-tick digest of what the sequence processor sent. Defaults ON;
  // admins who find it noisy can flip it off at /notification-settings.
  sequenceActivity      Boolean  @default(true) @map("sequence_activity")

  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("notification_preferences")
}

model ZohoConfig {
  id            String   @id @default(uuid())
  clientId      String   @map("client_id")
  clientSecret  String   @map("client_secret")
  refreshToken  String?  @map("refresh_token")
  accessToken   String?  @map("access_token")  @db.Text
  tokenExpiry   DateTime? @map("token_expiry")
  dataCenter    String   @default("us") @map("data_center")
  orgId         String?  @map("org_id")
  enabled       Boolean  @default(false)
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("zoho_config")
}

model BrandingConfig {
  id             String   @id @default(uuid())
  companyName    String   @map("company_name")
  logoPath       String?  @map("logo_path")
  website        String?
  primaryColor   String?  @map("primary_color")
  accentColor    String?  @map("accent_color")
  footerText     String?  @map("footer_text") @db.Text
  copyrightText  String?  @map("copyright_text")
  updatedAt      DateTime @updatedAt @map("updated_at")
  updatedBy      String?  @map("updated_by")

  @@map("branding_config")
}

model CustomerUser {
  id             String          @id @default(uuid())
  email          String          @unique
  name           String
  password       String?
  phone          String?
  profilePicture String?         @map("profile_picture")
  companyName    String?         @map("company_name")
  leadIds        Json            @default("[]") @map("lead_ids")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  socialAccounts    SocialAccount[]
  notifications     CustomerNotification[]
  pairingSessions   PairingSession[]

  @@map("customer_users")
}

model CustomerNotification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      CustomerUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String   @db.Text
  type      String   @default("info")
  link      String?
  readAt    DateTime? @map("read_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, readAt])
  @@map("customer_notifications")
}

model PairingSession {
  id              String        @id @default(uuid())
  token           String        @unique
  status          String        @default("PENDING")
  customerUserId  String?       @map("customer_user_id")
  customerUser    CustomerUser? @relation(fields: [customerUserId], references: [id], onDelete: SetNull)
  expiresAt       DateTime      @map("expires_at")
  redeemedAt      DateTime?     @map("redeemed_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@index([expiresAt])
  @@map("pairing_sessions")
}

model SocialAccount {
  id         String       @id @default(uuid())
  provider   AuthProvider
  providerId String       @map("provider_id")
  userId     String       @map("user_id")
  user       CustomerUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  email      String?
  name       String?
  avatarUrl  String?      @map("avatar_url")
  createdAt  DateTime     @default(now()) @map("created_at")

  @@unique([provider, providerId])
  @@map("social_accounts")
}

// ── Smart Sequences ──────────────────────────────────────

enum SequenceGoal {
  BOOK_MEETING
  GET_REPLY
  DRIVE_PURCHASE
  NURTURE_ONLY
}

enum SequenceStatus {
  DRAFT
  ACTIVE
  PAUSED
}

enum EnrollmentTrigger {
  MANUAL
  STAGE_CHANGE
  LEAD_CREATED
  ADDED_TO_LIST
}

enum WaitUnit {
  HOURS
  DAYS
  WEEKS
}

enum StepCondition {
  ALWAYS
  OPENED
  NOT_OPENED
  CLICKED
  NOT_CLICKED
  REPLIED
  NOT_REPLIED
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  COMPLETED
  EXITED
  REMOVED
}

enum ContactAction {
  NONE
  OPENED
  CLICKED
  REPLIED
}

model SmartSequence {
  id                String            @id @default(uuid())
  name              String
  goal              SequenceGoal
  status            SequenceStatus    @default(DRAFT)
  enrollmentTrigger EnrollmentTrigger @default(MANUAL) @map("enrollment_trigger")
  triggerConfig     Json              @default("{}") @map("trigger_config")
  audienceTags      Json              @default("[]") @map("audience_tags")
  exitConditions    Json              @default("[]") @map("exit_conditions")
  reEnrollAfterDays Int?              @map("re_enroll_after_days")
  createdBy         String?           @map("created_by")
  updatedBy         String?           @map("updated_by")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  triggerListId     String?           @map("trigger_list_id")
  triggerList        ContactList?     @relation(fields: [triggerListId], references: [id], onDelete: SetNull)

  steps       SequenceStep[]
  enrollments SequenceEnrollment[]

  @@map("smart_sequences")
}

model SequenceStep {
  id              String         @id @default(uuid())
  sequenceId      String         @map("sequence_id")
  sequence        SmartSequence  @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  stepOrder       Int            @map("step_order")
  templateId      String         @map("template_id")
  template        EmailTemplate  @relation(fields: [templateId], references: [id], onDelete: Restrict)
  waitValue       Int            @default(1) @map("wait_value")
  waitUnit        WaitUnit       @default(DAYS) @map("wait_unit")
  condition       StepCondition  @default(ALWAYS)
  goToStepOrder   Int?           @map("go_to_step_order")
  exitOnCondition StepCondition? @map("exit_on_condition")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@unique([sequenceId, stepOrder])
  @@map("sequence_steps")
}

model SequenceEnrollment {
  id               String           @id @default(uuid())
  sequenceId       String           @map("sequence_id")
  sequence         SmartSequence    @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  leadId           String           @map("lead_id")
  lead             Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  currentStepOrder Int              @default(1) @map("current_step_order")
  status           EnrollmentStatus @default(ACTIVE)
  enrolledAt       DateTime         @default(now()) @map("enrolled_at")
  lastEmailSentAt  DateTime?        @map("last_email_sent_at")
  lastAction       ContactAction    @default(NONE) @map("last_action")
  nextSendAt       DateTime?        @map("next_send_at")
  exitReason       String?          @map("exit_reason")
  lockedUntil      DateTime?        @map("locked_until")
  retryCount       Int              @default(0) @map("retry_count")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@unique([sequenceId, leadId])
  @@index([status, nextSendAt, lockedUntil])
  @@map("sequence_enrollments")
}

model SequenceEnrollmentArchive {
  id               String    @id
  sequenceId       String    @map("sequence_id")
  leadId           String    @map("lead_id")
  currentStepOrder Int       @map("current_step_order")
  status           String
  enrolledAt       DateTime  @map("enrolled_at")
  lastEmailSentAt  DateTime? @map("last_email_sent_at")
  lastAction       String    @map("last_action")
  nextSendAt       DateTime? @map("next_send_at")
  exitReason       String?   @map("exit_reason")
  retryCount       Int       @map("retry_count")
  createdAt        DateTime  @map("created_at")
  updatedAt        DateTime  @map("updated_at")
  archivedAt       DateTime  @default(now()) @map("archived_at")

  @@index([leadId])
  @@index([sequenceId])
  @@map("sequence_enrollments_archive")
}

// ── Contact Lists ────────────────────────────────────────

enum ListType {
  STATIC
  DYNAMIC
}

enum MembershipSource {
  MANUAL
  RULE
  IMPORT
}

model ContactList {
  id              String     @id @default(uuid())
  name            String
  type            ListType
  description     String?    @db.Text
  isSuppression   Boolean    @default(false) @map("is_suppression")
  filters         Json       @default("[]")
  lastRefreshedAt DateTime?  @map("last_refreshed_at")
  createdBy       String?    @map("created_by")
  updatedBy       String?    @map("updated_by")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  members            ListMembership[]
  triggeredSequences SmartSequence[]

  @@map("contact_lists")
}

model ListMembership {
  id       String           @id @default(uuid())
  listId   String           @map("list_id")
  list     ContactList      @relation(fields: [listId], references: [id], onDelete: Cascade)
  leadId   String           @map("lead_id")
  lead     Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  source   MembershipSource @default(MANUAL)
  addedBy  String?          @map("added_by")
  addedAt  DateTime         @default(now()) @map("added_at")

  @@unique([listId, leadId])
  @@map("list_memberships")
}

// ── App Factory ──────────────────────────────────────────────────────

enum AppFactoryStatus {
  IDEATING
  DESIGNING
  SUBMITTED
  BUILDING
  DELIVERED
  ENHANCING
}

enum AppFactoryBuildStatus {
  SUBMITTED
  IN_REVIEW
  BUILDING
  TESTING
  READY
  DELIVERED
}

enum AppStorePlatform {
  IOS
  ANDROID
}

enum EnhancementStatus {
  REQUESTED
  REVIEWED
  APPROVED
  BUILDING
  DELIVERED
}

model AppFactoryProject {
  id              String              @id @default(uuid())
  publicId        String              @unique @map("public_id")
  status          AppFactoryStatus    @default(IDEATING)
  customerName    String?             @map("customer_name")
  customerEmail   String?             @map("customer_email")
  companyName     String?             @map("company_name")
  leadId          String?             @map("lead_id")
  invitationToken String?             @unique @map("invitation_token")
  idea            String              @db.Text
  platforms       Json                @default("[\"ios\", \"android\"]")
  targetAudience  String?             @db.Text @map("target_audience")
  keyFeatures     Json                @default("[]") @map("key_features")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  flows           AppFactoryFlow[]
  builds          AppFactoryBuild[]
  appStoreConfigs AppStoreConfig[]
  enhancements    AppFactoryEnhancement[]

  @@map("app_factory_projects")
}

model AppFactoryFlow {
  id                     String            @id @default(uuid())
  projectId              String            @map("project_id")
  project                AppFactoryProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version                Int               @default(1)
  flowType               String            @default("WIREFRAME") @map("flow_type")
  nodes                  Json              @default("[]")
  edges                  Json              @default("[]")
  screens                Json              @default("[]")
  requirements           Json              @default("[]")
  isFinalized            Boolean           @default(false) @map("is_finalized")
  aiConversationHistory  Json              @default("[]") @map("ai_conversation_history")
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")

  @@unique([projectId, version])
  @@map("app_factory_flows")
}

model AppFactoryBuild {
  id            String                @id @default(uuid())
  projectId     String                @map("project_id")
  project       AppFactoryProject     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version       Int                   @default(1)
  status        AppFactoryBuildStatus @default(SUBMITTED)
  requirements  Json                  @default("{}") @map("requirements_snapshot")
  submittedAt   DateTime              @default(now()) @map("submitted_at")
  deliveredAt   DateTime?             @map("delivered_at")
  notes         String?               @db.Text
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")

  enhancements  AppFactoryEnhancement[]

  @@map("app_factory_builds")
}

model AppStoreConfig {
  id                   String            @id @default(uuid())
  projectId            String            @map("project_id")
  project              AppFactoryProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  platform             AppStorePlatform
  accountId            String?           @map("account_id")
  bundleId             String?           @map("bundle_id")
  apiKey               String?           @db.Text @map("api_key")
  connectionVerified   Boolean           @default(false) @map("connection_verified")
  connectionVerifiedAt DateTime?         @map("connection_verified_at")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")

  @@unique([projectId, platform])
  @@map("app_store_configs")
}

model AppFactoryEnhancement {
  id            String            @id @default(uuid())
  projectId     String            @map("project_id")
  project       AppFactoryProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  buildId       String?           @map("build_id")
  build         AppFactoryBuild?  @relation(fields: [buildId], references: [id], onDelete: SetNull)
  description   String            @db.Text
  aiDiff        Json?             @map("ai_diff")
  status        EnhancementStatus @default(REQUESTED)
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  @@map("app_factory_enhancements")
}

// ── Native Meeting Booking (replaces the Zoho Bookings iframe) ──────
//
// Customers book a 15- or 30-minute call directly on the customer portal
// via /book?leadId=<id> (deep-linked from email campaigns) or via the
// Book Meeting tab inside their project. Admins manage meeting types and
// see bookings in /meetings on the admin portal.

enum MeetingBookingStatus {
  CONFIRMED
  CANCELLED
  COMPLETED
}

model MeetingType {
  id          String    @id @default(uuid())
  name        String
  durationMin Int       @map("duration_min")
  description String?   @db.Text
  isActive    Boolean   @default(true) @map("is_active")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  bookings MeetingBooking[]

  @@map("meeting_types")
}

model MeetingBooking {
  id               String               @id @default(uuid())
  meetingTypeId    String               @map("meeting_type_id")
  meetingType      MeetingType          @relation(fields: [meetingTypeId], references: [id], onDelete: Restrict)
  // Optional lead link. Email-campaign clicks pass ?leadId=...; cold
  // bookings (someone shares the /book URL) leave this null and we'll
  // match on email later via a backfill if needed.
  leadId           String?              @map("lead_id")
  lead             Lead?                @relation(fields: [leadId], references: [id], onDelete: SetNull)
  attendeeName     String               @map("attendee_name")
  attendeeEmail    String               @map("attendee_email")
  attendeePhone    String?              @map("attendee_phone")
  notes            String?              @db.Text
  startsAt         DateTime             @map("starts_at")
  endsAt           DateTime             @map("ends_at")
  timezone         String?              // IANA TZ the attendee saw when booking (display-only)
  status           MeetingBookingStatus @default(CONFIRMED)
  conferencingLink String?              @map("conferencing_link")
  // Zoom integration. Provisioning is deferred to a cron tick so the
  // booking flow doesn't depend on Zoom being reachable.
  zoomMeetingId       String?  @map("zoom_meeting_id")
  conferencingError   String?  @map("conferencing_error") @db.Text
  conferencingAttempts Int     @default(0) @map("conferencing_attempts")
  conferencingNotifiedAt DateTime? @map("conferencing_notified_at")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  @@index([startsAt])
  @@index([leadId])
  @@map("meeting_bookings")
}

// ── System Health (singleton table for cron heartbeat) ──────────────

model SystemHealth {
  id                                 String    @id @default("singleton")
  lastSequenceProcessAt              DateTime? @map("last_sequence_process_at")
  lastSequenceProcessResult          Json?     @map("last_sequence_process_result")
  lastDraftProcessAt                 DateTime? @map("last_draft_process_at")
  lastDraftProcessResult             Json?     @map("last_draft_process_result")
  lastArchiveAt                      DateTime? @map("last_archive_at")
  lastArchiveResult                  Json?     @map("last_archive_result")
  sequenceProcessConsecutiveFailures Int       @default(0) @map("sequence_process_consecutive_failures")
  draftProcessConsecutiveFailures    Int       @default(0) @map("draft_process_consecutive_failures")
  updatedAt                          DateTime  @updatedAt @map("updated_at")

  @@map("system_health")
}
