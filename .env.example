# Database
DATABASE_URL=postgresql://postgres:YOUR_STRONG_PASSWORD@localhost:5432/leads_portal

# Session
SESSION_SECRET=generate-a-random-64-char-string-here

# SMTP (Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# Customer Portal
CUSTOMER_PORTAL_URL=http://localhost:3001

# Company
COMPANY_NAME=KITLabs Inc

# External API Token
API_TOKEN=generate-a-random-api-token-here

# AWS Deployment (used by CI/CD)
AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-1
EC2_HOST=your-ec2-public-ip
EC2_USER=ubuntu
DOMAIN_ADMIN=admin.yourdomain.com
DOMAIN_CUSTOMER=portal.yourdomain.com
